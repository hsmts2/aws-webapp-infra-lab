# study.example.env
# CloudFormation デプロイ用パラメータの例。
# 使い方:
#   cp study.example.env study.env
#   vi study.env        # 実値を埋める（study.env はGit管理しない）
#
# デプロイ:
#   aws cloudformation deploy \
#     --template-file templates/aws-webapp-infra-lab.yaml \
#     --stack-name aws-webapp-infra-lab \
#     --capabilities CAPABILITY_NAMED_IAM \
#     --parameter-overrides $(cat parameters/study.env)
#
# 注意:
#   - DomainName と PublicHostedZoneId を空のままにすると、ACM証明書・HTTPS:443
#     リスナー・公開Route53レコードは作成されない（学習用の最小構成）。
#   - ドメインで運用する場合のみ、両方を実値で埋める。

ProjectName=sample
KeyName=sample-key
YourIpCidr=xxx.xxx.xxx.xxx/32
AlbTargetPort=3000
S3AccessMode=LeastPrivilege

# --- ドメインを使う場合のみ設定（使わないなら空のまま）---
DomainName=
PublicHostedZoneId=
